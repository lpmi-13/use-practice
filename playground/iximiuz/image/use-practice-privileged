#!/usr/bin/env bash
set -euo pipefail

die() {
  echo "use-practice-privileged: $*" >&2
  exit 1
}

need_root() {
  [ "$(id -u)" = "0" ] || die "must run as root"
}

valid_run_id() {
  [[ "${1:-}" =~ ^r[0-9a-fA-F]{8}$ ]]
}

run_suffix() {
  local rid="$1"
  valid_run_id "$rid" || die "invalid run id"
  printf '%s\n' "${rid#r}"
}

netns_name() {
  printf 'up-%s\n' "$(run_suffix "$1")"
}

veth_host_name() {
  printf 'veth%sh\n' "$(run_suffix "$1")"
}

veth_peer_name() {
  printf 'veth%sp\n' "$(run_suffix "$1")"
}

valid_uid_gid() {
  [[ "${1:-}" =~ ^[0-9]+$ ]] && [[ "${2:-}" =~ ^[0-9]+$ ]]
}

valid_cgroup_dir() {
  [[ "${1:-}" =~ ^/sys/fs/cgroup/use-practice-r[0-9a-fA-F]{8}-[a-z][a-z0-9-]*-oom$ ]]
}

valid_state_program() {
  [[ "${1:-}" =~ ^/var/lib/use-practice/state/network/\.runtime/bin/[a-z][a-z0-9-]*$ ]]
}

service_from_program() {
  basename "$1"
}

cgroup_write() {
  local path="${1:-}"
  local value="${2:-}"
  local dir file

  if [ "$path" = "/sys/fs/cgroup/cgroup.subtree_control" ]; then
    [ "$value" = "+memory" ] || die "invalid cgroup.subtree_control value"
    printf '%s\n' "$value" > "$path"
    return 0
  fi

  dir="$(dirname "$path")"
  file="$(basename "$path")"
  valid_cgroup_dir "$dir" || die "invalid cgroup path"
  case "$file" in
    memory.max|memory.swap.max)
      [[ "$value" =~ ^[0-9]+$ ]] || die "invalid memory limit"
      ;;
    memory.oom.group)
      [[ "$value" =~ ^[01]$ ]] || die "invalid oom group value"
      ;;
    cgroup.procs)
      [[ "$value" =~ ^[0-9]+$ ]] && [ "$value" -gt 1 ] || die "invalid pid"
      ;;
    *)
      die "unsupported cgroup file"
      ;;
  esac
  printf '%s\n' "$value" > "$path"
}

netns_setup() {
  local rid="$1"
  local suffix netns host peer
  local host_ip="10.231.0.1"
  local peer_ip="10.231.0.2"

  suffix="$(run_suffix "$rid")"
  netns="up-$suffix"
  host="veth${suffix}h"
  peer="veth${suffix}p"

  command -v ip >/dev/null 2>&1 || die "ip command not found"

  ip netns add "$netns"
  if ! ip link add "$host" type veth peer name "$peer"; then
    ip netns delete "$netns" >/dev/null 2>&1 || true
    return 1
  fi
  if ! ip addr add "$host_ip/30" dev "$host"; then
    ip link delete "$host" >/dev/null 2>&1 || true
    ip netns delete "$netns" >/dev/null 2>&1 || true
    return 1
  fi
  if ! ip link set "$host" up; then
    ip link delete "$host" >/dev/null 2>&1 || true
    ip netns delete "$netns" >/dev/null 2>&1 || true
    return 1
  fi
  if ! ip link set "$peer" netns "$netns"; then
    ip link delete "$host" >/dev/null 2>&1 || true
    ip netns delete "$netns" >/dev/null 2>&1 || true
    return 1
  fi
  if ! ip netns exec "$netns" ip addr add "$peer_ip/30" dev "$peer"; then
    ip netns delete "$netns" >/dev/null 2>&1 || true
    ip link delete "$host" >/dev/null 2>&1 || true
    return 1
  fi
  if ! ip netns exec "$netns" ip link set lo up; then
    ip netns delete "$netns" >/dev/null 2>&1 || true
    ip link delete "$host" >/dev/null 2>&1 || true
    return 1
  fi
  if ! ip netns exec "$netns" ip link set "$peer" up; then
    ip netns delete "$netns" >/dev/null 2>&1 || true
    ip link delete "$host" >/dev/null 2>&1 || true
    return 1
  fi
}

cmd="${1:-}"
shift || true

case "$cmd" in
  check)
    exit 0
    ;;
  netns-setup)
    need_root
    [ "$#" -eq 1 ] || die "usage: netns-setup <run-id>"
    netns_setup "$1"
    ;;
  netns-delete)
    need_root
    [ "$#" -eq 1 ] || die "usage: netns-delete <run-id>"
    ip netns delete "$(netns_name "$1")"
    ;;
  link-delete)
    need_root
    [ "$#" -eq 1 ] || die "usage: link-delete <run-id>"
    ip link delete "$(veth_host_name "$1")"
    ;;
  netns-exec)
    need_root
    [ "$#" -eq 2 ] || die "usage: netns-exec <run-id> <program>"
    rid="$1"
    program="$2"
    valid_run_id "$rid" || die "invalid run id"
    valid_state_program "$program" || die "invalid program path"
    [ -x "$program" ] || die "program is not executable"
    uid="${SUDO_UID:-}"
    gid="${SUDO_GID:-}"
    valid_uid_gid "$uid" "$gid" || die "missing invoking user id"
    command -v setpriv >/dev/null 2>&1 || die "setpriv command not found"
    service="$(service_from_program "$program")"
    exec ip netns exec "$(netns_name "$rid")" \
      env USE_PRACTICE_RUN_ID="$rid" USE_PRACTICE_SERVICE="$service" \
      setpriv --reuid "$uid" --regid "$gid" --clear-groups "$program"
    ;;
  cgroup-create)
    need_root
    [ "$#" -eq 3 ] || die "usage: cgroup-create <dir> <uid> <gid>"
    dir="$1"
    uid="$2"
    gid="$3"
    valid_cgroup_dir "$dir" || die "invalid cgroup dir"
    valid_uid_gid "$uid" "$gid" || die "invalid uid/gid"
    mkdir "$dir"
    chown "$uid:$gid" "$dir" || true
    chown "$uid:$gid" \
      "$dir/cgroup.procs" \
      "$dir/memory.max" \
      "$dir/memory.swap.max" \
      "$dir/memory.oom.group" 2>/dev/null || true
    ;;
  cgroup-write)
    need_root
    [ "$#" -eq 2 ] || die "usage: cgroup-write <path> <value>"
    cgroup_write "$1" "$2"
    ;;
  cgroup-rmdir)
    need_root
    [ "$#" -eq 1 ] || die "usage: cgroup-rmdir <dir>"
    valid_cgroup_dir "$1" || die "invalid cgroup dir"
    rmdir "$1"
    ;;
  *)
    die "unknown command"
    ;;
esac
